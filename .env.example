# 复制为 .env 后再填真实值

# 发件方式一：Outlook / Office365
# JOBDIGEST_SMTP_HOST=smtp.office365.com
# JOBDIGEST_SMTP_PORT=587

# 发件方式二：Gmail（需要 App Password）
# JOBDIGEST_SMTP_HOST=smtp.gmail.com
# JOBDIGEST_SMTP_PORT=587

JOBDIGEST_SMTP_USER=your_email@example.com
JOBDIGEST_SMTP_PASSWORD=your_app_password
JOBDIGEST_MAIL_FROM=your_email@example.com
JOBDIGEST_MAIL_TO=your_email@example.com
